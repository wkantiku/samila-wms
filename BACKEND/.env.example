# SAMILA WMS 3PL Backend - Environment Configuration

# Database Configuration
DATABASE_URL=postgresql://samila:samila123@localhost:5432/samila_wms
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=samila
DATABASE_PASSWORD=samila123
DATABASE_NAME=samila_wms

# Application Configuration
APP_NAME=SAMILA WMS 3PL
APP_VERSION=1.0.0
ENVIRONMENT=development

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Settings
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8100"]
CORS_ALLOW_CREDENTIALS=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# File Upload
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIRECTORY=uploads/

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Timezone
TIMEZONE=Asia/Bangkok
