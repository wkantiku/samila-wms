# ── Samila WMS Environment Variables ─────────────────
# Copy file นี้เป็น .env แล้วแก้ค่าให้ถูกต้อง
# cp .env.example .env

# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql://samila:samila_password@db:5432/samila_wms
POSTGRES_USER=samila
POSTGRES_PASSWORD=samila_password
POSTGRES_DB=samila_wms

# ── Backend ───────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Frontend ──────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000
REACT_APP_VERSION=1.0.0
REACT_APP_NAME=Samila WMS

# ── Environment ───────────────────────────────────
ENVIRONMENT=production
DEBUG=false
